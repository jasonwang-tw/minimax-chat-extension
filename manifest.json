{
  "manifest_version": 3,
  "name": "MiniMax AI Chat",
  "version": "1.5.3",
  "description": "串接 MiniMax API 的 AI 對話擴充功能，點擊即可開啟側邊欄與 AI 對話",
  "permissions": [
    "storage",
    "sidePanel",
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://api.minimax.io/*",
    "https://generativelanguage.googleapis.com/*",
    "https://translate.google.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "MiniMax AI Chat"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "options/options.html"
}
